## 🔧 开发规范

### TypeScript 规范

```typescript
// ✅ 正确：使用明确的类型定义
interface Message {
  id: string;
  role: 'user' | 'assistant' | 'system';
  content: string;
  timestamp: number;
  streaming?: boolean;
}

// ✅ 正确：使用类型守卫
function isAssistantMessage(msg: Message): msg is Message & { role: 'assistant' } {
  return msg.role === 'assistant';
}

// ❌ 错误：避免使用 any
const data: any = await fetchData(); // 不推荐

// ✅ 正确：使用具体类型
const data: ApiResponse = await fetchData();
```

### React 组件规范

```typescript
// ✅ 正确：函数组件 + TypeScript
interface MessageBubbleProps {
  message: Message;
  onRetry?: () => void;
}

export const MessageBubble = ({ message, onRetry }: MessageBubbleProps) => {
  // 组件实现
};

// ✅ 正确：使用 memo 优化性能（关键组件）
export const MessageBubble = memo(
  ({ message, onRetry }: MessageBubbleProps) => {
    // 组件实现
  },
  (prev, next) => prev.message.id === next.message.id &&
                 prev.message.content === next.message.content
);
```

### 命名约定

```typescript
// 组件：PascalCase
export const MessageBubble = () => { };
export const ChatWorkspace = () => { };

// 文件名：与默认导出一致
// MessageBubble.tsx
// ChatWorkspace.tsx

// Hook：use 前缀 + camelCase
export const useAppTheme = () => { };
export const useChatStore = () => { };

// 服务/工具函数：camelCase
export const sendMessage = async () => { };
export const formatTimestamp = () => { };

// 常量：UPPER_SNAKE_CASE
export const MAX_MESSAGE_LENGTH = 4000;
export const DEFAULT_MODEL = 'gpt-4';

// 类型/接口：PascalCase
interface ChatMessage { }
type AIProvider = 'openai' | 'anthropic';
```

### 状态管理（Zustand）

```typescript
// ✅ 正确：使用 Zustand 管理全局状态
interface ChatStore {
  conversations: Record<string, Conversation>;
  currentConversationId: string | null;

  // Actions
  addMessage: (conversationId: string, message: Message) => void;
  setCurrentConversation: (id: string) => void;
}

export const useChatStore = create<ChatStore>((set) => ({
  conversations: {},
  currentConversationId: null,

  addMessage: (conversationId, message) => set((state) => ({
    conversations: {
      ...state.conversations,
      [conversationId]: {
        ...state.conversations[conversationId],
        messages: [...state.conversations[conversationId].messages, message],
      },
    },
  })),

  setCurrentConversation: (id) => set({ currentConversationId: id }),
}));

// ✅ 正确：局部状态使用 useState
const [isLoading, setIsLoading] = useState(false);
```

### 样式规范（NativeWind）

```typescript
// ✅ 正确：使用 NativeWind (Tailwind CSS)
<View className="flex-1 bg-background p-4">
  <Text className="text-lg font-semibold text-foreground">
    标题
  </Text>
</View>

// ✅ 正确：条件样式
<View className={`p-4 ${isActive ? 'bg-primary' : 'bg-secondary'}`}>
  内容
</View>

// ✅ 正确：主题感知
const theme = useAppTheme();
<View style={{ backgroundColor: theme.background }}>
```

