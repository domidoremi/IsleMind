## 🚨 错误处理

### 错误处理原则

```typescript
// ✅ 正确：返回可诊断状态
try {
  const response = await provider.call(prompt);
  return { success: true, data: response };
} catch (error) {
  return {
    success: false,
    error: error.message,
    diagnostics: {
      provider: provider.name,
      timestamp: Date.now(),
      context: { prompt: prompt.slice(0, 100) },
    },
  };
}

// ❌ 错误：丢弃用户输入
try {
  await provider.call(prompt);
} catch (error) {
  return null; // 不推荐！
}
```

### 降级策略

```typescript
// ✅ 正确：保留降级路径
async function embedText(text: string): Promise<number[]> {
  // 优先使用本地模型
  if (localModelAvailable) {
    return await localEmbed(text);
  }

  // 降级到 hash embedding
  return await hashEmbedding(text);
}
```

