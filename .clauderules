│   │   ├── settings/         # 设置相关组件
│   │   ├── providers/        # 服务商配置组件
│   │   ├── ui/isle/          # Isle UI 组件库
│   │   └── navigation/       # 导航组件
│   ├── services/             # 业务逻辑层
│   │   ├── ai/              # AI 服务商集成
│   │   ├── agent/           # Agent 工作流
│   │   ├── rag.ts           # RAG 检索
│   │   ├── chatRunner.ts    # 对话运行时
│   │   └── storage.ts       # 存储服务
│   ├── store/                # Zustand 状态管理
