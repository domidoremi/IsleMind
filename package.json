{
  "name": "islemind",
  "version": "1.0.3",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "test:provider-intelligence": "node scripts/provider-intelligence-tests.js",
