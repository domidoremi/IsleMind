{
  "name": "islemind",
  "version": "1.0.6",
  "packageManager": "bun@1.3.14",
  "main": "expo-router/entry",
  "scripts": {
    "start": "node node_modules/expo/bin/cli start",
    "postinstall": "node scripts/patch-onnxruntime-16kb.js",
    "android": "node node_modules/expo/bin/cli run:android",
    "ios": "node node_modules/expo/bin/cli run:ios",
    "test:provider-intelligence": "node scripts/provider-intelligence-tests.js",
    "type-check": "node node_modules/typescript/bin/tsc --noEmit",
    "doctor": "node node_modules/expo-doctor/bin/expo-doctor.js",
    "test:qa-audit:self": "node scripts/qa-coverage-audit.js --self-test",
    "test:current-apk-smoke": "node scripts/collect-current-apk-smoke.js",
    "test:provider-runtime-android": "node scripts/collect-provider-runtime-android.js",
    "test:memory-review-smoke": "node scripts/collect-memory-review-smoke.js",
    "test:work-artifact-smoke": "node scripts/collect-work-artifact-smoke.js",
    "test:qa-audit": "node scripts/qa-coverage-audit.js",
    "apk:local": "node scripts/build-local-android-apk.js --variant no-model --debug",
    "apk:local:models": "node scripts/build-local-android-apk.js --variant with-model-small --debug",
    "apk:local:all": "node scripts/build-local-android-apk.js --all-variants --debug",
    "apk:local:release": "node scripts/build-local-android-apk.js --variant no-model --release",
    "apk:local:release:models": "node scripts/build-local-android-apk.js --variant with-model-small --release",
    "apk:local:release:all": "node scripts/build-local-android-apk.js --all-variants --release",
    "apk:prepare-models": "node scripts/prepare-model-bundle.js",
    "apk:validate-16kb": "node scripts/validate-android-16kb-apk.js",
    "test:ui-naming": "node scripts/ui-naming-audit.js"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@shopify/flash-list": "2.0.2",
    "expo": "~54.0.35",
    "expo-application": "~7.0.8",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-blur": "~15.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.11",
    "expo-crypto": "~15.0.9",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.10",
    "expo-image-picker": "~17.0.8",
    "expo-intent-launcher": "~13.0.8",
    "expo-linking": "~8.0.8",
    "expo-localization": "~17.0.9",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-speech": "~14.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "i18next": "^24.2.3",
    "lucide-react-native": "^1.17.0",
    "moti": "^0.30.0",
    "nativewind": "^4.2.4",
    "onnxruntime-react-native": "^1.24.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^15.4.1",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.11",
    "expo-doctor": "^1.19.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2"
  },
  "private": true
}
